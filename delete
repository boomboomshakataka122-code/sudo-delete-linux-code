#!/bin/bash

if [ "$1" = "linux" ]; then

echo "delete utility (https://github.com/boomboomshakataka122-code/sudo-delete-linux-code)"
echo

progress=0

delete_file() {
    echo -n "Deleting $1"
    sleep 0.05
    echo "...done"
}

update_progress() {
    progress=$((progress + 1))
    printf "Progress: %d%%\n" "$progress"
}

echo "Initializing Linux removal sequence..."
sleep 2
echo "Scanning mounted filesystems..."
sleep 1
echo "Root filesystem detected."
sleep 1
echo "Preparing deletion routines..."
sleep 2
echo

echo "Phase 1: Removing core binaries"

for file in bash sh ls cp mv rm mkdir cat chmod chown uname mount umount ps grep echo kill; do
    delete_file "/bin/$file"
    update_progress
done

echo
echo "Phase 2: Removing system configuration"

for file in passwd shadow group hostname hosts fstab sudoers issue resolv.conf; do
    delete_file "/etc/$file"
    update_progress
done

echo
echo "Phase 3: Removing boot components"

for file in vmlinuz initrd.img System.map config; do
    delete_file "/boot/$file"
    update_progress
done

delete_file "/boot/grub/grub.cfg"
update_progress

delete_file "/boot/grub/grubenv"
update_progress

echo
echo "Phase 4: Removing shared libraries"

for file in libc.so.6 libm.so.6 libpthread.so.0 libdl.so.2 libutil.so.1 libcrypt.so.1; do
    delete_file "/lib/$file"
    update_progress
done

echo
echo "Phase 5: Removing kernel modules"

modules=(ext4 xfs btrfs overlay loop dm_mod fuse vfat nls_utf8)
for module in "${modules[@]}"; do
    delete_file "/lib/modules/kernel/$module.ko"
    update_progress
done

echo
echo "Phase 6: Removing system logs"

for file in syslog kern.log auth.log dpkg.log boot.log; do
    delete_file "/var/log/$file"
    update_progress
done

echo
echo "Phase 7: Removing user environment"

delete_file "/home/user/.bashrc"
update_progress

delete_file "/home/user/.profile"
update_progress

delete_file "/home/user/Documents"
update_progress

delete_file "/home/user/Downloads"
update_progress

delete_file "/home/user/Desktop"
update_progress

echo
echo "Phase 8: Removing package manager data"

delete_file "/var/lib/dpkg/status"
update_progress

delete_file "/var/lib/dpkg/available"
update_progress

delete_file "/var/lib/apt/lists"
update_progress

echo
echo "Phase 9: Destroying bootloader"

delete_file "/boot/efi/EFI/ubuntu/grubx64.efi"
update_progress

delete_file "/boot/efi/EFI/ubuntu/shimx64.efi"
update_progress

echo
echo "Phase 10: Removing swap"

echo -n "Deleting /swapfile"
sleep 3
echo "...done"

echo
echo "Phase 11: Wiping disk sectors"

for i in {1..10}; do
    echo "Overwriting disk sector group $i/10..."
    sleep 0.4
done

echo "...done"

echo
echo "Performing final verification..."
sleep 3

echo "Scanning filesystem remnants..."
sleep 2

echo "No Linux installation detected."

echo
echo "Linux removal completed successfully."
echo "Reboot the system to finalize the removal."

else
    echo "delete: unknown target"
fi
